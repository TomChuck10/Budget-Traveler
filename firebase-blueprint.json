{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "points": { "type": "number" },
        "joinedAt": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "name", "role", "points", "joinedAt", "avatar"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    }
  }
}
